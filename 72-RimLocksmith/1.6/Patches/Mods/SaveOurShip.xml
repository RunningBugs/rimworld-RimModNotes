<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Save Our Ship 2</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationConditional">
          <xpath>/Defs/ThingDef[thingClass="Building_ShipAirlock"]/comps</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/ThingDef[thingClass="Building_ShipAirlock"]</xpath>
            <value><comps /></value>
          </nomatch>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[thingClass="Building_ShipAirlock"]/comps</xpath>
          <value><li Class="RunningBugs.RimLocksmith.CompProperties_RimLocksmithDoor" /></value>
        </li>
        <li Class="PatchOperationConditional">
          <xpath>/Defs/ThingDef[thingClass="Building_ShipAirlock"]/inspectorTabs</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/ThingDef[thingClass="Building_ShipAirlock"]</xpath>
            <value><inspectorTabs /></value>
          </nomatch>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[thingClass="Building_ShipAirlock"]/inspectorTabs</xpath>
          <value><li>RunningBugs.RimLocksmith.ITab_RimLocksmith</li></value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
